# MongoDB connection string. Use a dedicated database on your existing instance,
# e.g. mongodb://user:pass@127.0.0.1:27017/tibeb?authSource=admin
DATABASE_URL="mongodb://127.0.0.1:27017/tibeb"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-with-openssl-rand-base64-32"

# Base URL of the deployment (used by Auth.js callbacks)
AUTH_URL="http://localhost:3000"

# Public contact channels surfaced in the UI
NEXT_PUBLIC_WHATSAPP="+251900000000"
NEXT_PUBLIC_CONTACT_EMAIL="guide@example.com"
