// Tibeb — data model.
// Only DYNAMIC data lives here (availability + bookings + admin).
// Static presentation content (hero, guide bio, places) lives in the i18n
// message files so it is translatable and editable without touching the DB.
// When you later want to manage that content from the admin, add models here.

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum BookingStatus {
  PENDING // request received, waiting on guide confirmation
  CONFIRMED // guide is available, client notified (and/or paid)
  DECLINED // guide unavailable
  CANCELLED // cancelled after confirmation
  COMPLETED // tour finished
}

enum DayStatus {
  AVAILABLE
  BOOKED
  UNAVAILABLE
}

/// A single day the guide marks in their calendar.
model Availability {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  date      DateTime
  status    DayStatus @default(AVAILABLE)
  note      String? // e.g. "morning only", "Lalibela day-trip"
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([date])
  @@index([status])
}

/// A timeline entry for tracking (icons/timestamps in the UI).
type TimelineEntry {
  label String
  at    DateTime
  kind  String // "status" | "progress" | "email" | "note"
}

/// A booking request made by a client.
model Booking {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  startDate   DateTime
  endDate     DateTime? // for multi-day tours
  clientName  String
  clientEmail String
  clientPhone String?
  numPeople   Int           @default(2)
  tourType    String? // references a place/tour key from content
  message     String?
  locale      String        @default("en") // language the client booked in
  status      BookingStatus @default(PENDING)

  // --- owner workflow / hand-off to guide ---
  assignedToGuide Boolean         @default(false)
  progress        String          @default("PENDING") // PENDING | IN_PROCESS | DONE
  paymentLink     String? // Grow (or other) deposit link pasted by the owner
  timeline        TimelineEntry[]

  // --- payment fields ---
  amount Float?
  paid   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([startDate])
}

/// Admin user(s). Start with one; the role field lets you grow to a team later.
model Admin {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  email        String   @unique
  name         String?
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
}
